% mybraintrainer.sty
\ProvidesPackage{mybraintrainer}[2025/07/19 Brain Training styles and macros]

%% Exercise counter
\newcounter{excounter}
\setcounter{excounter}{0}

%% Difficulty stars: 1=easy 2=medium 3=hard
\newcommand{\DifficultyStars}[1]{%
  \ifcase#1
  \or {\color{orange}\faStar}\faStarRegular\faStarRegular%
  \or {\color{orange}\faStar\faStar}\faStarRegular%
  \or {\color{orange}\faStar\faStar\faStar}%
  \fi
}

%% Timer badge
\newcommand{\TimerBadge}[1]{%
  \tikz[baseline=(b.base)]{%
    \node[fill=gray!20, rounded corners=3pt, inner sep=4pt,
          font=\small\bfseries] (b) {\faClock\ #1};%
  }%
}

%% Category badge
\NewDocumentCommand{\CategoryBadge}{ o m }{%
  \tikz[baseline=(b.base)]{%
    \node[fill=\IfValueTF{#1}{#1}{gray!20}, rounded corners=2pt,
          inner sep=3pt, font=\footnotesize\bfseries] (b) {#2};%
  }%
}

%% TOC button
\newcommand{\TOCButtonTall}[3]{%
  \begin{beamercolorbox}[%
      wd=0.45\textwidth,
      sep=1.2ex,
      center,
      rounded=true,shadow=true]{#1}%
    \vbox to 3.5ex{%
      \vfil
      \centering
      \hyperlink{#2}{\Large\usebeamerfont{#1}#3}
      \vfil
    }%
  \end{beamercolorbox}%
}

%% Exercise slide: \ExerciseSlide[badge]{stars}{time}{problem}
\NewDocumentCommand{\ExerciseSlide}{ o m m m }{%
  \stepcounter{excounter}%
  \subsection{Zadanie \theexcounter}%
  \begin{frame}%
    \IfValueT{#1}{%
      \begin{tikzpicture}[remember picture,overlay]
        \node[anchor=north east, xshift=-0.4cm, yshift=-0.4cm]
          at (current page.north east) {#1};
      \end{tikzpicture}%
    }%
    \centering
    \vspace{0.8em}
    {\large\bfseries Zadanie \theexcounter\par}
    \vspace{0.4em}
    {\large \DifficultyStars{#2}\par}
    \vspace{0.3em}
    \TimerBadge{#3}\par
    \vspace{1.2em}
    {\LARGE\bfseries #4\par}
  \end{frame}%
}

%% Answer slide: \AnswerSlide[badge]{answer}{optional one-liner hint}
%% Answer is displayed large. Hint (if any) appears small below.
\NewDocumentCommand{\AnswerSlide}{ o m m }{%
  \begin{frame}%
    \IfValueT{#1}{%
      \begin{tikzpicture}[remember picture,overlay]
        \node[anchor=north east, xshift=-0.5cm, yshift=-0.5cm]
          at (current page.north east) {#1};
      \end{tikzpicture}%
    }%
    \frametitle{Odpowiedź \theexcounter}%
    \centering
    \vspace{1.5em}
    {\Huge\bfseries #2\par}%
    \ifblank{#3}{}{\vspace{1.5em}{\small\itshape #3\par}}%
  \end{frame}%
}

%% Chunked TOC
\newcommand{\ChunkedTOC}[2][30]{%
  \foreach \start in {1,\numexpr#1+1\relax,...,#2} {
    \edef\endsec{\number\numexpr\start + #1 - 1\relax}%
    \begin{frame}{Spis treści}%
      \scriptsize
      \begin{multicols}{2}
        \tableofcontents[sections={\start-\endsec}, hideallsubsections]
      \end{multicols}
    \end{frame}%
  }
}
